#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX 256

// Structure for Huffman Tree Node
struct Node {
    char data;
    int freq;
    struct Node *left;
    struct Node *right;
};

// Global dictionary to store generated character paths
char dictionary[MAX][MAX];

// Create a new node
struct Node* createNode(char data, int freq) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->data = data;
    newNode->freq = freq;
    newNode->left = NULL;
    newNode->right = NULL;
    return newNode;
}

// Swap nodes
void swap(struct Node** a, struct Node** b) {
    struct Node* temp = *a;
    *a = *b;
    *b = temp;
}

// Sort nodes by frequency
void sortNodes(struct Node* arr[], int size) {
    for (int i = 0; i < size - 1; i++) {
        for (int j = 0; j < size - i - 1; j++) {
            if (arr[j]->freq > arr[j + 1]->freq) {
                swap(&arr[j], &arr[j + 1]);
            }
        }
    }
}

// Traverse tree to generate and store prefix codes (0s and 1s)
void buildDictionary(struct Node* root, int path[], int top) {
    if (root->left) {
        path[top] = 0;
        buildDictionary(root->left, path, top + 1);
    }
    if (root->right) {
        path[top] = 1;
        buildDictionary(root->right, path, top + 1);
    }
    // Leaf Node: save path string into dictionary mapping
    if (root->left == NULL && root->right == NULL) {
        int i;
        for (i = 0; i < top; i++) {
            dictionary[(unsigned char)root->data][i] = path[i] + '0';
        }
        dictionary[(unsigned char)root->data][i] = '\0';
        printf("%c : %s\n", root->data, dictionary[(unsigned char)root->data]);
    }
}

// ENCODING: Converts words into a full code of 0s and 1s
void encodeText(const char* text, char* encodedOutput) {
    encodedOutput[0] = '\0';
    for (int i = 0; text[i] != '\0'; i++) {
        strcat(encodedOutput, dictionary[(unsigned char)text[i]]);
    }
}

// DECODING: Converts a full code of 0s and 1s back into words
void decodeText(struct Node* root, const char* encodedStr) {
    struct Node* current = root;
    printf("Decoded Output : ");
    
    for (int i = 0; encodedStr[i] != '\0'; i++) {
        if (encodedStr[i] == '0') {
            current = current->left;
        } else if (encodedStr[i] == '1') {
            current = current->right;
        }

        // If leaf is reached, print symbol and jump back to tree top
        if (current->left == NULL && current->right == NULL) {
            printf("%c", current->data);
            current = root;
        }
    }
    printf("\n");
}

